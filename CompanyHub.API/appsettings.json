{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "cs": "Data Source=.;Initial Catalog=CompanyHub;Integrated Security=True;Encrypt=False"
  },
  "JwtSetting": {
    "Key": "My_JWT_Secret_Key",
    "Issuer": "CompanyHub",
    "Audience": "CompanyHubUsers",
    "DurationInMinutes": 60
  },
  "EmailSetting": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Email": "your-email@gmail.com",
    "Password": "your-app-password",
    "EnableSSL": true
  },
  "Radis": {
    "ConnectionString": "localhost:6379"
  },
  "PaymobSetting": {
    "ApiKey": "YOUR_API_KEY",
    "IntegrationId": "YOUR_INTEGRATION_ID",
    "IFrameId": "YOUR_IFRAME_ID",
    "HmacSecret": "YOUR_HMAC_SECRET",
    "BaseUrl": "https://accept.paymob.com/api"
  }

}
